{
  "name": "android-image-architect",
  "version": "2.1.0",
  "description": "Ferramenta gráfica para desempacotar e reempacotar imagens de partições Android",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.aia.architect",
    "productName": "Android Image Architect",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "python",
        "to": "python"
      },
      {
        "from": "tools",
        "to": "tools"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    }
  }
}